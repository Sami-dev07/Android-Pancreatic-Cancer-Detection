<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Pancreatic" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand (match web 'clinical') -->
        <item name="colorPrimary">@color/clinical_700</item>
        <item name="colorPrimaryVariant">@color/clinical_900</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/clinical_600</item>
        <item name="colorSecondaryVariant">@color/clinical_900</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/slate_900</item>
        <item name="android:colorBackground">@color/slate_50</item>

        <item name="android:statusBarColor" tools:targetApi="l">@color/clinical_900</item>

        <!-- Material component defaults -->
        <item name="materialButtonStyle">@style/Widget.Pancreatic.Button</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Pancreatic.Body</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.Pancreatic.Title</item>
    </style>

    <!-- Splash theme used only by SplashActivity -->
    <style name="Theme.Pancreatic.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/slate_50</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/clinical_900</item>
        <item name="colorPrimary">@color/clinical_700</item>
        <item name="colorPrimaryVariant">@color/clinical_900</item>
        <item name="colorOnPrimary">@color/white</item>
    </style>
</resources>


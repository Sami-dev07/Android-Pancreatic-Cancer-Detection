<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/slate_50"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Model Performance"
            android:textAppearance="@style/TextAppearance.Pancreatic.Title"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading dashboard..."
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.Pancreatic.Body" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/summaryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            style="@style/Widget.Pancreatic.Card"
            app:cardUseCompatPadding="true"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/summaryTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Summary"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/slate_900" />

                <TextView
                    android:id="@+id/summarySubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Best model: -"
                    android:layout_marginTop="4dp"
                    android:textAppearance="@style/TextAppearance.Pancreatic.Body" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/summaryChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:singleLine="false"
                    app:chipSpacingHorizontal="8dp"
                    app:chipSpacingVertical="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Details"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/slate_900"
            android:layout_marginTop="14dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/blocksRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Plots"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/slate_900"
            android:layout_marginTop="14dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/plotsRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

